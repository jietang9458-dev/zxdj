/* page styles */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 9999;
}
.modal-dialog {
  width: 85%;
  background: #fff;
  border-radius: 16px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}
.modal-title {
  padding: 24px 24px 12px;
  font-size: 18px;
  font-weight: 500;
  text-align: center;
  color: #333;
}
.modal-content {
  padding: 10px 24px 24px;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.avatar-wrapper {
  padding: 0;
  width: 80px !important;
  height: 80px !important;
  border-radius: 40px;
  margin-bottom: 20px;
  background-color: #f6f6f6;
  position: relative;
}
.avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}
.avatar-hint {
  position: absolute;
  bottom: 0;
  width: 100%;
  background: rgba(0,0,0,0.3);
  color: #fff;
  font-size: 10px;
  text-align: center;
  line-height: 20px;
  height: 20px;
}
.weui-input {
  width: 100%;
  height: 48px;
  background: #f6f6f6;
  border-radius: 8px;
  padding: 0 16px;
  font-size: 16px;
  text-align: center;
  box-sizing: border-box;
}
.modal-footer {
  display: flex;
  border-top: 1px solid #eee;
}
.modal-btn {
  flex: 1;
  text-align: center;
  padding: 16px 0;
  font-size: 17px;
  background: #fff;
  border: none;
  border-radius: 0;
  line-height: normal;
}
.modal-btn::after {
  border: none;
}
.modal-btn.cancel {
  color: #999;
  border-right: 1px solid #eee;
}
.modal-btn.confirm {
  color: #D4AF37;
  font-weight: 500;
}
