/* page styles */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 9999;
}

.modal-dialog {
  width: 80%;
  background: #fff;
  border-radius: 16px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.modal-title {
  padding: 24px 24px 12px;
  font-size: 18px;
  font-weight: 500;
  text-align: center;
  color: #333;
}

.modal-content {
  padding: 0 24px 24px;
  font-size: 15px;
  color: #666;
  text-align: center;
  line-height: 1.5;
}

.modal-footer {
  display: flex;
  border-top: 1px solid #eee;
}

.modal-btn {
  flex: 1;
  text-align: center;
  padding: 16px 0;
  font-size: 17px;
  background: #fff;
  border: none;
  border-radius: 0;
  line-height: normal;
}

.modal-btn::after {
  border: none;
}

.modal-btn.cancel {
  color: #666;
  border-right: 1px solid #eee;
}

.modal-btn.confirm {
  color: #07c160;
  font-weight: 500;
}
