{
  "entities": {
    "ShortDrama": {
      "title": "Short Drama",
      "description": "Information about a short drama series",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "imageUrl": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["title", "imageUrl"]
    },
    "FilmingBase": {
      "title": "Filming Base",
      "description": "Details about a filming location/base",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "location": { "type": "string" },
        "imageUrl": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["title", "imageUrl"]
    },
    "MallProduct": {
      "title": "Mall Product",
      "description": "Products available in the mall",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "price": { "type": "number" },
        "imageUrl": { "type": "string" },
        "category": { "type": "string" }
      },
      "required": ["title", "price", "imageUrl"]
    },
    "PageContent": {
      "title": "Page Content",
      "description": "Dynamic content for various pages in the app",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "banners": { "type": "array", "items": { "type": "object" } },
        "config": { "type": "object" }
      }
    },
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "nickname": { "type": "string" },
        "avatar": { "type": "string" },
        "bio": { "type": "string" },
        "role": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/dramas/{dramaId}": {
      "schema": "ShortDrama",
      "description": "Collection of short dramas"
    },
    "/bases/{baseId}": {
      "schema": "FilmingBase",
      "description": "Collection of filming bases"
    },
    "/products/{productId}": {
      "schema": "MallProduct",
      "description": "Collection of mall products"
    },
    "/pages/{pageId}": {
      "schema": "PageContent",
      "description": "Global settings and page-specific content"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    }
  }
}
